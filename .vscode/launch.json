{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Launch EduChatAI",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build", // Kích hoạt task tên là "build" trước khi chạy
      "program": "${workspaceFolder}/src/EduChatAI.Web/bin/Debug/net8.0/EduChatAI.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/EduChatAI.Web",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/src/EduChatAI.Web/Views",
        "/_content": "${workspaceFolder}"
      }
    }
  ]
}