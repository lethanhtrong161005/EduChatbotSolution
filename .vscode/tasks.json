{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build", // Tên nhãn này phải trùng khớp với preLaunchTask ở trên
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/EduChatAI.Web/EduChatAI.Web.csproj", // Đường dẫn chính xác đến file web
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoColor"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}