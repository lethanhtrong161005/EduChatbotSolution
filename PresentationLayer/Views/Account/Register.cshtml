@using BusinessLayer.DTOs;
@model RegisterRequestDto

@{
    ViewData["Title"] = "Register - EduChatAI";
    Layout = null; // No layout for register page
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Global Color Scheme -->
    <link rel="stylesheet" href="~/css/colors.css">

    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --gradient-primary: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            --gradient-secondary: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            width: 100%;
        }

        body {
            background: var(--gradient-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-family-base);
            min-height: 100vh;
            position: relative;
            overflow: hidden;
        }

        /* Animated Background */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--gradient-primary);
            z-index: -1;
        }

        .bubble {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            animation: float var(--float-duration) infinite ease-in-out;
        }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0px) translateX(0px);
                opacity: 0.5;
            }
            50% {
                transform: translateY(-30px) translateX(20px);
                opacity: 0.3;
            }
        }

        .container-login {
            display: flex;
            height: 100vh;
            width: 100%;
            background: var(--gradient-primary);
        }

        /* Left Side - Branding (Hidden on mobile) */
        .login-sidebar {
            flex: 1;
            background: var(--gradient-primary);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
            padding: var(--spacing-8);
            position: relative;
            overflow: hidden;
        }

        .login-sidebar::before {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            top: -100px;
            right: -100px;
            animation: pulse 4s ease-in-out infinite;
        }

        .login-sidebar::after {
            content: '';
            position: absolute;
            width: 200px;
            height: 200px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50%;
            bottom: -50px;
            left: -50px;
            animation: pulse 5s ease-in-out infinite 1s;
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
                opacity: 0.5;
            }
            50% {
                transform: scale(1.1);
                opacity: 0.3;
            }
        }

        .sidebar-content {
            text-align: center;
            z-index: 1;
        }

        .sidebar-logo {
            font-size: 4rem;
            margin-bottom: var(--spacing-6);
            animation: slideInLeft 0.8s ease-out;
        }

        .sidebar-title {
            font-size: 2.5rem;
            font-weight: var(--font-weight-bold);
            margin-bottom: var(--spacing-4);
            animation: slideInLeft 0.8s ease-out 0.1s both;
        }

        .sidebar-subtitle {
            font-size: 1.125rem;
            margin-bottom: var(--spacing-6);
            opacity: 0.9;
            animation: slideInLeft 0.8s ease-out 0.2s both;
        }

        .sidebar-features {
            list-style: none;
            text-align: left;
            margin-top: var(--spacing-8);
            animation: slideInLeft 0.8s ease-out 0.3s both;
        }

        .sidebar-features li {
            margin-bottom: var(--spacing-4);
            display: flex;
            align-items: center;
        }

        .sidebar-features i {
            font-size: 1.5rem;
            margin-right: var(--spacing-4);
            background: rgba(255, 255, 255, 0.2);
            padding: var(--spacing-3);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        @@keyframes slideInLeft {
            from {
                transform: translateX(-50px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Right Side - Register Form */
        .login-form-container {
            /* Force light-mode color variables regardless of OS dark mode */
            --color-text-primary: #111827;
            --color-text-secondary: #6b7280;
            --color-bg-light: #ffffff;
            --color-border-light: #e5e7eb;
            --color-border-neutral: #d1d5db;

            flex: 1;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: var(--spacing-8);
            position: relative;
        }

        .login-form-box {
            width: 100%;
            max-width: 420px;
            animation: slideInRight 0.8s ease-out;
        }

        @@keyframes slideInRight {
            from {
                transform: translateX(50px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .login-header {
            text-align: center;
            margin-bottom: var(--spacing-6);
        }

        .login-header h1 {
            font-size: 1.75rem;
            color: var(--color-text-primary);
            font-weight: var(--font-weight-bold);
            margin-bottom: var(--spacing-2);
        }

        .login-header p {
            color: var(--color-text-secondary);
            font-size: var(--font-size-sm);
        }

        .form-group {
            margin-bottom: var(--spacing-6);
        }

        .form-label {
            display: block;
            margin-bottom: var(--spacing-2);
            color: var(--color-text-primary);
            font-weight: var(--font-weight-medium);
            font-size: var(--font-size-sm);
        }

        .form-control {
            padding: var(--spacing-3) var(--spacing-4);
            border: 2px solid var(--color-border-light);
            border-radius: var(--radius-lg);
            font-size: var(--font-size-base);
            transition: all var(--transition-base);
            background-color: var(--color-bg-light);
        }

        .form-control:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(46, 204, 113, 0.1);
            outline: none;
        }

        .form-control::placeholder {
            color: var(--color-text-secondary);
        }

        .input-icon-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            right: var(--spacing-4);
            top: 50%;
            transform: translateY(-50%);
            color: var(--color-text-secondary);
            pointer-events: none;
        }

        .toggle-password {
            position: absolute;
            right: var(--spacing-4);
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--color-text-secondary);
            cursor: pointer;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            transition: color var(--transition-base);
        }

        .toggle-password:hover {
            color: var(--color-primary);
        }

        .form-control-with-icon {
            padding-right: 2.5rem;
        }

        .form-check {
            display: flex;
            align-items: center;
            margin-bottom: var(--spacing-6);
        }

        .form-check-input {
            width: 20px;
            height: 20px;
            margin-right: var(--spacing-2);
            cursor: pointer;
            border: 2px solid var(--color-border-light);
            border-radius: var(--radius-sm);
            accent-color: var(--color-primary);
        }

        .form-check-label {
            color: var(--color-text-primary);
            font-size: var(--font-size-sm);
            cursor: pointer;
            margin: 0;
        }

        .btn-login {
            width: 100%;
            padding: var(--spacing-3) var(--spacing-4);
            background: var(--gradient-primary);
            border: none;
            border-radius: var(--radius-lg);
            color: white;
            font-size: var(--font-size-base);
            font-weight: var(--font-weight-semibold);
            cursor: pointer;
            transition: all var(--transition-base);
            position: relative;
            overflow: hidden;
            margin-bottom: var(--spacing-4);
        }

        .btn-login:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(46, 204, 113, 0.3);
        }

        .btn-login:active:not(:disabled) {
            transform: translateY(0);
        }

        .btn-login:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

        /* Loading Animation */
        .spinner-loading {
            display: none;
            position: absolute;
            left: var(--spacing-4);
            top: 50%;
            transform: translateY(-50%);
        }

        .btn-login.loading {
            color: transparent;
        }

        .btn-login.loading .spinner-loading {
            display: inline-block;
        }

        .spinner-border-sm {
            width: 1.5rem;
            height: 1.5rem;
            border-width: 2px;
        }

        .alert-error {
            background-color: rgba(231, 76, 60, 0.1);
            border: 1px solid var(--color-error);
            color: var(--color-error);
            padding: var(--spacing-3) var(--spacing-4);
            border-radius: var(--radius-lg);
            margin-bottom: var(--spacing-6);
            animation: slideInDown 0.5s ease-out;
        }

        .alert-success {
            background-color: rgba(46, 204, 113, 0.1);
            border: 1px solid var(--color-success);
            color: var(--color-success);
            padding: var(--spacing-3) var(--spacing-4);
            border-radius: var(--radius-lg);
            margin-bottom: var(--spacing-6);
            animation: slideInDown 0.5s ease-out;
        }

        @@keyframes slideInDown {
            from {
                transform: translateY(-20px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .signup-link {
            text-align: center;
            color: var(--color-text-secondary);
            font-size: var(--font-size-sm);
            margin-top: var(--spacing-6);
        }

        .signup-link a {
            color: var(--color-primary);
            text-decoration: none;
            font-weight: var(--font-weight-semibold);
            transition: color var(--transition-base);
        }

        .signup-link a:hover {
            color: var(--color-primary-dark);
        }

        /* Social Login Buttons */
        .social-divider {
            display: flex;
            align-items: center;
            margin-bottom: var(--spacing-6);
            opacity: 0.5;
        }

        .social-divider::before,
        .social-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--color-border-light);
        }

        .social-divider span {
            padding: 0 var(--spacing-3);
            font-size: var(--font-size-sm);
            color: var(--color-text-secondary);
        }

        .social-buttons {
            display: flex;
            gap: var(--spacing-3);
            margin-bottom: var(--spacing-6);
        }

        .btn-social {
            flex: 1;
            padding: var(--spacing-3);
            border: 1px solid var(--color-border-light);
            background: white;
            border-radius: var(--radius-lg);
            cursor: pointer;
            transition: all var(--transition-base);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: var(--spacing-2);
        }

        .btn-social:hover:not(:disabled) {
            border-color: var(--color-primary);
            background: rgba(46, 204, 113, 0.05);
        }

        .btn-social:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-social i {
            font-size: 1.25rem;
        }

        .text-danger {
            color: var(--color-error);
            display: block;
            margin-top: var(--spacing-1);
            font-size: var(--font-size-sm);
        }

        /* Responsive Design */
        @@media (max-width: 992px) {
            .container-login {
                flex-direction: column;
            }

            .login-sidebar {
                min-height: 200px;
                padding: var(--spacing-6);
                justify-content: flex-end;
            }

            .sidebar-title {
                font-size: 1.75rem;
            }

            .sidebar-features {
                display: none;
            }

            .login-form-container {
                min-height: auto;
            }

            .login-form-box {
                max-width: 100%;
            }
        }

        @@media (max-width: 576px) {
            .login-form-container {
                padding: var(--spacing-4);
            }

            .login-form-box {
                width: 100%;
            }

            .login-header {
                margin-bottom: var(--spacing-4);
            }

            .login-header h1 {
                font-size: 1.5rem;
                margin-bottom: var(--spacing-1);
            }

            .login-header p {
                font-size: var(--font-size-xs);
            }

            .btn-login {
                padding: var(--spacing-2) var(--spacing-3);
                font-size: var(--font-size-sm);
            }

            .social-buttons {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <!-- Background Animation -->
    <div class="bg-animation"></div>

    <!-- Main Register Container -->
    <div class="container-login">
        <!-- Left Sidebar - Branding -->
        <div class="login-sidebar d-none d-lg-flex">
            <div class="sidebar-content">
                <div class="sidebar-logo">
                    <i class="fas fa-robot"></i>
                </div>
                <h2 class="sidebar-title">EduChatAI</h2>
                <p class="sidebar-subtitle">Smart Educational Companion</p>

                <ul class="sidebar-features">
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>AI-Powered Learning</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Instant Q&A Support</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Personalized Education</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Right Side - Register Form -->
        <div class="login-form-container">
            <div class="login-form-box">
                <!-- Header -->
                <div class="login-header">
                    <h1>Register Account</h1>
                    <p>Get your free EduChatAI account now.</p>
                </div>

                <!-- Error Messages -->
                @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
                {
                    <div class="alert-error">
                        <i class="fas fa-exclamation-circle"></i>
                        @Html.ValidationSummary(false)
                    </div>
                }

                <!-- Register Form -->
                <form id="registerForm" method="post" asp-controller="Account" asp-action="Register">
                    <!-- Email Input -->
                    <div class="form-group">
                        <label class="form-label" asp-for="Email">
                            <i class="fas fa-envelope"></i> Email Address
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="email"
                                   class="form-control form-control-with-icon"
                                   placeholder="Enter your email"
                                   asp-for="Email"
                                   required>
                            <i class="fas fa-envelope input-icon"></i>
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- Full Name Input -->
                    <div class="form-group">
                        <label class="form-label" asp-for="FullName">
                            <i class="fas fa-user"></i> Username
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="text"
                                   class="form-control form-control-with-icon"
                                   placeholder="Enter your full name"
                                   asp-for="FullName"
                                   required>
                            <i class="fas fa-user input-icon"></i>
                        </div>
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <!-- Password Input -->
                    <div class="form-group">
                        <label class="form-label" asp-for="Password">
                            <i class="fas fa-lock"></i> Password
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="password"
                                   class="form-control form-control-with-icon password-input"
                                   id="password"
                                   placeholder="Enter your password"
                                   asp-for="Password"
                                   required>
                            <button type="button" class="toggle-password" data-target="password">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <!-- Confirm Password Input -->
                    <div class="form-group">
                        <label class="form-label" asp-for="ConfirmPassword">
                            <i class="fas fa-lock"></i> Confirm Password
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="password"
                                   class="form-control form-control-with-icon password-input"
                                   id="confirmPassword"
                                   placeholder="Re-enter your password"
                                   asp-for="ConfirmPassword"
                                   required>
                            <button type="button" class="toggle-password" data-target="confirmPassword">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <!-- Terms Checkbox -->
                    <div class="form-check">
                        <input type="checkbox"
                               class="form-check-input"
                               id="agreeTerms"
                               required>
                        <label class="form-check-label" for="agreeTerms">
                            I agree to the <a href="#" style="color: var(--color-primary);">Terms of Service</a>
                        </label>
                    </div>

                    <!-- Register Button with Loading Animation -->
                    <button type="submit" class="btn-login" id="registerBtn">
                        <span class="spinner-loading">
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        </span>
                        <span class="btn-text">Register</span>
                    </button>
                </form>

                <!-- Social Divider -->
                <div class="social-divider">
                    <span>Sign up using</span>
                </div>

                <!-- Social Buttons (Decorative) -->
                <div class="social-buttons">
                    <button type="button" class="btn-social" disabled>
                        <i class="fab fa-facebook-f" style="color: #1877f2;"></i>
                    </button>
                    <button type="button" class="btn-social" disabled>
                        <i class="fab fa-google" style="color: #ea4335;"></i>
                    </button>
                </div>

                <!-- Login Link -->
                <div class="signup-link">
                    Already have an account? <a asp-controller="Account" asp-action="Login">Login</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- jQuery and Validation Scripts for client-side validation -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <!-- Register Interactions Script -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const registerForm = document.getElementById('registerForm');
            const registerBtn = document.getElementById('registerBtn');

            // Add loading animation on form submit
            registerForm.addEventListener('submit', function(e) {
                // Only add loading state if form is valid
                if (registerForm.checkValidity() === false) {
                    e.preventDefault();
                    e.stopPropagation();
                } else {
                    registerBtn.classList.add('loading');
                    registerBtn.disabled = true;
                }
            });

            // Toggle password visibility
            const toggleButtons = document.querySelectorAll('.toggle-password');
            toggleButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    const targetId = this.getAttribute('data-target');
                    const passwordInput = document.getElementById(targetId);
                    const icon = this.querySelector('i');

                    if (passwordInput.type === 'password') {
                        passwordInput.type = 'text';
                        icon.classList.remove('fa-eye');
                        icon.classList.add('fa-eye-slash');
                    } else {
                        passwordInput.type = 'password';
                        icon.classList.remove('fa-eye-slash');
                        icon.classList.add('fa-eye');
                    }
                });
            });
        });

        // Animate bubbles in background
        function createBubbles() {
            const bgAnimation = document.querySelector('.bg-animation');
            const bubbleCount = window.innerWidth > 768 ? 5 : 2;

            for (let i = 0; i < bubbleCount; i++) {
                const bubble = document.createElement('div');
                bubble.className = 'bubble';

                const size = Math.random() * 100 + 50;
                bubble.style.width = size + 'px';
                bubble.style.height = size + 'px';

                bubble.style.left = Math.random() * 100 + '%';
                bubble.style.top = Math.random() * 100 + '%';

                bubble.style.setProperty('--float-duration', Math.random() * 10 + 8 + 's');

                bgAnimation.appendChild(bubble);
            }
        }

        createBubbles();

        // Prevent double form submission
        let isSubmitting = false;
        document.getElementById('registerForm').addEventListener('submit', function(e) {
            if (isSubmitting) {
                e.preventDefault();
                return;
            }
            isSubmitting = true;
        });
    </script>
</body>
</html>
