@using BusinessLayer.DTOs;
@model RegisterRequestDto

@{
    ViewData["Title"] = "Register - EduChatAI";
    Layout = null; // No layout for register page
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Global Color Scheme -->
    <link rel="stylesheet" href="~/css/colors.css">

    <!-- Account Auth Styles -->
    <link rel="stylesheet" href="~/css/account-auth.css">

    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Background Animation -->
    <div class="bg-animation"></div>

    <!-- Main Register Container -->
    <div class="container-login">
        <!-- Left Sidebar - Branding -->
        <div class="login-sidebar d-none d-lg-flex">
            <div class="sidebar-content">
                <div class="sidebar-logo">
                    <i class="fas fa-robot"></i>
                </div>
                <h2 class="sidebar-title">EduChatAI</h2>
                <p class="sidebar-subtitle">Smart Educational Companion</p>

                <ul class="sidebar-features">
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>AI-Powered Learning</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Instant Q&A Support</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Personalized Education</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Right Side - Register Form -->
        <div class="login-form-container">
            <div class="login-form-box">
                <!-- Header -->
                <div class="login-header login-header--compact">
                    <h1>Register Account</h1>
                    <p>Get your free EduChatAI account now.</p>
                </div>

                <!-- Error Messages -->
                @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
                {
                    <div class="alert-error">
                        <i class="fas fa-exclamation-circle"></i>
                        @Html.ValidationSummary(false)
                    </div>
                }

                <!-- Register Form -->
                <form id="registerForm" method="post" asp-controller="Account" asp-action="Register">
                    <!-- Email Input -->
                    <div class="form-group">
                        <label class="form-label" asp-for="Email">
                            <i class="fas fa-envelope"></i> Email Address
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="email"
                                   class="form-control form-control-with-icon"
                                   placeholder="Enter your email"
                                   asp-for="Email"
                                   required>
                            <i class="fas fa-envelope input-icon"></i>
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- Full Name Input -->
                    <div class="form-group">
                        <label class="form-label" asp-for="FullName">
                            <i class="fas fa-user"></i> Username
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="text"
                                   class="form-control form-control-with-icon"
                                   placeholder="Enter your full name"
                                   asp-for="FullName"
                                   required>
                            <i class="fas fa-user input-icon"></i>
                        </div>
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <!-- Password Input -->
                    <div class="form-group">
                        <label class="form-label" asp-for="Password">
                            <i class="fas fa-lock"></i> Password
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="password"
                                   class="form-control form-control-with-icon password-input"
                                   id="password"
                                   placeholder="Enter your password"
                                   asp-for="Password"
                                   required>
                            <button type="button" class="toggle-password" data-target="password">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <!-- Confirm Password Input -->
                    <div class="form-group">
                        <label class="form-label" asp-for="ConfirmPassword">
                            <i class="fas fa-lock"></i> Confirm Password
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="password"
                                   class="form-control form-control-with-icon password-input"
                                   id="confirmPassword"
                                   placeholder="Re-enter your password"
                                   asp-for="ConfirmPassword"
                                   required>
                            <button type="button" class="toggle-password" data-target="confirmPassword">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <!-- Terms Checkbox -->
                    <div class="form-check">
                        <input type="checkbox"
                               class="form-check-input"
                               id="agreeTerms"
                               required>
                        <label class="form-check-label" for="agreeTerms">
                            I agree to the <a href="#" style="color: var(--color-primary);">Terms of Service</a>
                        </label>
                    </div>

                    <!-- Register Button with Loading Animation -->
                    <button type="submit" class="btn-login" id="registerBtn">
                        <span class="spinner-loading">
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        </span>
                        <span class="btn-text">Register</span>
                    </button>
                </form>

                <!-- Social Divider -->
                <div class="social-divider">
                    <span>Sign up using</span>
                </div>

                <!-- Social Buttons (Decorative) -->
                <div class="social-buttons">
                    <button type="button" class="btn-social" disabled>
                        <i class="fab fa-facebook-f" style="color: #1877f2;"></i>
                    </button>
                    <button type="button" class="btn-social" disabled>
                        <i class="fab fa-google" style="color: #ea4335;"></i>
                    </button>
                </div>

                <!-- Login Link -->
                <div class="signup-link">
                    Already have an account? <a asp-controller="Account" asp-action="Login">Login</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- jQuery and Validation Scripts for client-side validation -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <!-- Register Interactions Script -->
    <script src="~/js/account-register.js"></script>
</body>
</html>
