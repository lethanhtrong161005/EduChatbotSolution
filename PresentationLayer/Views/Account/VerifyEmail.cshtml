@model VerifyEmailVm

@{
    ViewData["Title"] = "Verify Email - EduChatAI";
    Layout = null;
    var returnUrl = ViewData["ReturnUrl"]?.ToString() ?? "/home/index";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Global Color Scheme -->
    <link rel="stylesheet" href="~/css/colors.css">

    <!-- Shared Account Auth Styles (layout, sidebar, bubbles) -->
    <link rel="stylesheet" href="~/css/account-auth.css">

    <!-- Verify Email Specific Styles -->
    <link rel="stylesheet" href="~/css/account-verify-email.css">

    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Background Animation -->
    <div class="bg-animation"></div>

    <!-- Main Container -->
    <div class="container-login">

        <!-- Left Sidebar - Branding -->
        <div class="login-sidebar d-none d-lg-flex">
            <div class="sidebar-content">
                <div class="sidebar-logo">
                    <i class="fas fa-robot"></i>
                </div>
                <h2 class="sidebar-title">EduChatAI</h2>
                <p class="sidebar-subtitle">Smart Educational Companion</p>

                <ul class="sidebar-features">
                    <li>
                        <i class="fas fa-shield-alt"></i>
                        <span>Secure Verification</span>
                    </li>
                    <li>
                        <i class="fas fa-envelope-open-text"></i>
                        <span>Check Your Inbox</span>
                    </li>
                    <li>
                        <i class="fas fa-lock"></i>
                        <span>Your Data is Safe</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Right Side - Verification Form -->
        <div class="login-form-container">
            <div class="login-form-box">

                <!-- Header -->
                <div class="login-header login-header--compact">
                    <h1>Verify Your Email</h1>
                    <p class="verify-email-hint">
                        We sent a 6-digit code to<br>
                        <span class="verify-email-address">@Model.Email</span>
                    </p>
                </div>

                <!-- Server-side Error Messages -->
                @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
                {
                    <div class="alert-error">
                        <i class="fas fa-exclamation-circle"></i>
                        @Html.ValidationSummary(false)
                    </div>
                }

                <!-- OTP Verification Form -->
                <form id="verifyForm" method="post"
                      asp-route-return-url="@returnUrl">

                    @Html.AntiForgeryToken()

                    <!-- Hidden fields -->
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" id="hiddenCode" asp-for="Code" />

                    <!-- 6-Digit OTP Input Boxes -->
                    <div class="otp-input-group" role="group" aria-label="Verification code digits">
                        @for (int i = 0; i < 6; i++)
                        {
                            <input type="text"
                                   class="otp-digit"
                                   maxlength="1"
                                   inputmode="numeric"
                                   pattern="[0-9]"
                                   autocomplete="@(i == 0 ? "one-time-code" : "off")"
                                   aria-label="Digit @(i + 1) of 6" />
                        }
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="btn-verify" id="verifyBtn">
                        <span class="spinner-loading d-none">
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        </span>
                        <span class="btn-text">Verify Email</span>
                    </button>
                </form>

                <!-- Countdown + Resend -->
                <div class="resend-section">
                    <div id="countdownChip" class="countdown-chip">
                        <i class="fas fa-clock"></i>
                        Code expires in
                        <span id="countdownDisplay" data-seconds-remaining="180">03:00</span>
                    </div>

                    <span class="resend-label">Didn't receive it?</span>

                    <!-- Resend uses its own form for CSRF + AJAX -->
                    <form id="resendForm"
                          method="post"
                          action="@Url.Action("ResendCode", "Account")">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="email" value="@Model.Email" />
                        <button type="submit" id="resendBtn" class="btn-resend" disabled>
                            <i class="fas fa-paper-plane"></i> Resend Code
                        </button>
                    </form>
                </div>

                <!-- Back to Register -->
                <div class="signup-link mt-3">
                    Wrong email?
                    <a asp-controller="Account" asp-action="Register" asp-route-return-url="@returnUrl">
                        Start over
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toastContainer" class="toast-container"></div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Verify Email Interactions Script -->
    <script src="~/js/account-verify-email.js"></script>
</body>
</html>
