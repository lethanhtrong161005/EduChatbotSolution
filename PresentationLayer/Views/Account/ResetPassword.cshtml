@model ResetPasswordVm

@{
    ViewData["Title"] = "Reset Password - EduChatAI";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/colors.css">
    <link rel="stylesheet" href="~/css/account-auth.css">
    <link rel="stylesheet" href="~/css/account-verify-email.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="bg-animation"></div>

    <div class="container-login">
        <div class="login-sidebar d-none d-lg-flex">
            <div class="sidebar-content">
                <div class="sidebar-logo">
                    <i class="fas fa-robot"></i>
                </div>
                <h2 class="sidebar-title">EduChatAI</h2>
                <p class="sidebar-subtitle">Smart Educational Companion</p>

                <ul class="sidebar-features">
                    <li>
                        <i class="fas fa-key"></i>
                        <span>Verify Reset Code</span>
                    </li>
                    <li>
                        <i class="fas fa-lock"></i>
                        <span>Create a New Password</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Return to Learning</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="login-form-container">
            <div class="login-form-box">
                <div class="login-header login-header--compact">
                    <h1>Reset Password</h1>
                    <p class="verify-email-hint">
                        Enter the 6-digit code sent to<br>
                        <span class="verify-email-address">@Model.Email</span>
                    </p>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert-success">
                        <i class="fas fa-check-circle"></i>
                        @TempData["SuccessMessage"]
                    </div>
                }

                @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
                {
                    <div class="alert-error">
                        <i class="fas fa-exclamation-circle"></i>
                        @Html.ValidationSummary(false)
                    </div>
                }

                <form id="verifyForm" method="post" asp-controller="Account" asp-action="ResetPassword">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" id="hiddenCode" asp-for="Code" />

                    <div class="otp-input-group" role="group" aria-label="Password reset code digits">
                        @for (int i = 0; i < 6; i++)
                        {
                            <input type="text"
                                   class="otp-digit"
                                   maxlength="1"
                                   inputmode="numeric"
                                   pattern="[0-9]"
                                   autocomplete="@(i == 0 ? "one-time-code" : "off")"
                                   aria-label="Digit @(i + 1) of 6" />
                        }
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Password">
                            <i class="fas fa-lock"></i> New Password
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="password"
                                   class="form-control form-control-with-icon"
                                   asp-for="Password"
                                   placeholder="Enter a new password"
                                   required>
                            <i class="fas fa-lock input-icon"></i>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="ConfirmPassword">
                            <i class="fas fa-lock"></i> Confirm New Password
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="password"
                                   class="form-control form-control-with-icon"
                                   asp-for="ConfirmPassword"
                                   placeholder="Confirm your new password"
                                   required>
                            <i class="fas fa-lock input-icon"></i>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-verify" id="verifyBtn">
                        <span class="spinner-loading d-none">
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        </span>
                        <span class="btn-text">Reset Password</span>
                    </button>
                </form>

                <div class="resend-section">
                    <div id="countdownChip" class="countdown-chip">
                        <i class="fas fa-clock"></i>
                        Code expires in
                        <span id="countdownDisplay" data-seconds-remaining="180">03:00</span>
                    </div>

                    <span class="resend-label">Didn't receive it?</span>

                    <form id="resendForm"
                          method="post"
                          action="@Url.Action("ResendCode", "Account")">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="email" value="@Model.Email" />
                        <button type="submit" id="resendBtn" class="btn-resend" disabled>
                            <i class="fas fa-paper-plane"></i> Resend Code
                        </button>
                    </form>
                </div>

                <div class="signup-link mt-3">
                    Wrong email?
                    <a asp-controller="Account" asp-action="ForgotPassword">Start over</a>
                </div>
            </div>
        </div>
    </div>

    <div id="toastContainer" class="toast-container"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/account-verify-email.js"></script>
</body>
</html>
