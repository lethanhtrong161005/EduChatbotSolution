@model ForgotPasswordVm

@{
    ViewData["Title"] = "Forgot Password - EduChatAI";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/colors.css">
    <link rel="stylesheet" href="~/css/account-auth.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="bg-animation"></div>

    <div class="container-login">
        <div class="login-sidebar d-none d-lg-flex">
            <div class="sidebar-content">
                <div class="sidebar-logo">
                    <i class="fas fa-robot"></i>
                </div>
                <h2 class="sidebar-title">EduChatAI</h2>
                <p class="sidebar-subtitle">Smart Educational Companion</p>

                <ul class="sidebar-features">
                    <li>
                        <i class="fas fa-shield-alt"></i>
                        <span>Secure Account Recovery</span>
                    </li>
                    <li>
                        <i class="fas fa-envelope-open-text"></i>
                        <span>Email Verification Code</span>
                    </li>
                    <li>
                        <i class="fas fa-lock"></i>
                        <span>Reset Password Safely</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="login-form-container">
            <div class="login-form-box">
                <div class="login-header login-header--compact">
                    <h1>Forgot Password?</h1>
                    <p>Enter your email address and we will send a verification code.</p>
                </div>

                @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
                {
                    <div class="alert-error">
                        <i class="fas fa-exclamation-circle"></i>
                        @Html.ValidationSummary(false)
                    </div>
                }

                <form id="forgotPasswordForm" method="post" asp-controller="Account" asp-action="ForgotPassword">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label class="form-label" asp-for="Email">
                            <i class="fas fa-envelope"></i> Email Address
                        </label>
                        <div class="input-icon-wrapper">
                            <input type="email"
                                   class="form-control form-control-with-icon"
                                   asp-for="Email"
                                   placeholder="Enter your account email"
                                   required>
                            <i class="fas fa-envelope input-icon"></i>
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-login" id="forgotPasswordBtn">
                        <span class="spinner-loading">
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        </span>
                        <span class="btn-text">Send Reset Code</span>
                    </button>
                </form>

                <div class="signup-link">
                    Remember your password?
                    <a asp-controller="Account" asp-action="Login">Sign in</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('forgotPasswordForm')?.addEventListener('submit', function () {
            document.getElementById('forgotPasswordBtn')?.classList.add('loading');
            document.getElementById('forgotPasswordBtn')?.setAttribute('disabled', 'disabled');
        });

        const bgAnimation = document.querySelector('.bg-animation');
        const bubbleCount = window.innerWidth > 768 ? 5 : 2;
        for (let i = 0; i < bubbleCount; i++) {
            const bubble = document.createElement('div');
            bubble.className = 'bubble';
            const size = Math.random() * 100 + 50;
            bubble.style.width = `${size}px`;
            bubble.style.height = `${size}px`;
            bubble.style.left = `${Math.random() * 100}%`;
            bubble.style.top = `${Math.random() * 100}%`;
            bubble.style.setProperty('--float-duration', `${Math.random() * 10 + 8}s`);
            bgAnimation?.appendChild(bubble);
        }
    </script>
</body>
</html>
